#!/usr/bin/env bash

set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}

# Homebrew
if ! command -v brew &>/dev/null; then
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

brew install git git-lfs
brew install diffutils diff-so-fancy
brew install autoenv
brew install macvim
brew install oven-sh/bun/bun

# Claude Code stack — dependencies of the synced ~/.claude config:
#   jq         statusline.sh + account-info.sh
#   rtk        PreToolUse hook (`rtk hook claude`)
#   uv         installs/runs the headroom proxy (see run_once_after-install-claude-stack)
#   node       MCP servers (context7, etc.)
#   gh         GitHub ops referenced in CLAUDE.md
#   claude-code  the CLI itself
brew install jq uv node gh rtk
brew install --cask claude-code

brew install --cask karabiner-elements

# configure diff-so-fancy for git
git config --global core.pager "diff-so-fancy | less --tabs=4 -RFX"
git config --global interactive.diffFilter "diff-so-fancy --patch"

{{ else if eq .chezmoi.os "linux" -}}

if [ -f /etc/debian_version ] || [ -f /etc/lsb-release ]; then
    # Debian/Ubuntu
    sudo apt-get update -y
    sudo apt-get install -y git-all vim-nox

    # diff-so-fancy
    if [ ! -f /usr/local/bin/diff-so-fancy ]; then
        sudo git clone https://github.com/so-fancy/diff-so-fancy.git /usr/local/src/diff-so-fancy
        sudo ln -sf /usr/local/src/diff-so-fancy/diff-so-fancy /usr/local/bin/
    fi
    git config --global core.pager "diff-so-fancy | less --tabs=4 -RFX"
    git config --global interactive.diffFilter "diff-so-fancy --patch"

    # autoenv
    if [ ! -d "$HOME/.autoenv" ]; then
        git clone https://github.com/hyperupcall/autoenv.git ~/.autoenv
    fi

    # bun
    if ! command -v bun &>/dev/null && [ ! -x "$HOME/.bun/bin/bun" ]; then
        curl -fsSL https://bun.sh/install | bash
    fi

elif [ -f /etc/redhat-release ]; then
    # Red Hat/CentOS
    sudo yum -y update
    sudo yum -y install epel-release
    sudo yum -y install dnf
    sudo yum -y install vim-enhanced

    # autoenv
    if [ ! -d "$HOME/.autoenv" ]; then
        git clone https://github.com/hyperupcall/autoenv.git ~/.autoenv
    fi

    # bun
    if ! command -v bun &>/dev/null && [ ! -x "$HOME/.bun/bin/bun" ]; then
        curl -fsSL https://bun.sh/install | bash
    fi
fi

{{ end -}}
