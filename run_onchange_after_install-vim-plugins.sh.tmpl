#!/usr/bin/env bash
#
# Run vim-plug's :PlugInstall when the plugin list changes.
# The embedded hash ensures this script re-runs whenever
# dot_vim/dot_vimrc_plugins is updated.
#
# .vimrc_plugins sha256: {{ include "dot_vim/dot_vimrc_plugins" | sha256sum }}

set -euo pipefail

if ! command -v vim >/dev/null 2>&1; then
    echo "vim not installed, skipping PlugInstall"
    exit 0
fi

if [ ! -f "$HOME/.vim/autoload/plug.vim" ]; then
    echo "vim-plug not yet installed, skipping PlugInstall"
    exit 0
fi

vim +PlugInstall +qall
