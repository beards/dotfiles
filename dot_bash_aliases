# `cc` launches Claude Code through the local headroom compression proxy.
# ANTHROPIC_BASE_URL is controlled HERE (not in settings.json, whose env block
# would outrank the shell). Three states: proxy up → use it; installed but down →
# start via launchd and wait; not installed → fall back to the direct API.
cc() {
  local base="http://127.0.0.1:8787" label="com.simon.headroom-proxy"
  if command -v headroom >/dev/null 2>&1; then
    if ! curl -fs -m1 "$base/livez" >/dev/null 2>&1; then
      echo "⏳ headroom proxy down — starting via launchd…" >&2
      launchctl kickstart -k "gui/$(id -u)/$label" 2>/dev/null \
        || launchctl bootstrap "gui/$(id -u)" "$HOME/Library/LaunchAgents/$label.plist" 2>/dev/null
      local i=0
      until curl -fs -m1 "$base/livez" >/dev/null 2>&1; do
        sleep 0.3; i=$((i + 1))
        if [ "$i" -ge 33 ]; then   # ~10s cap → fall back instead of hanging
          echo "⚠ proxy didn't come up in 10s — using direct API" >&2
          unset ANTHROPIC_BASE_URL
          command claude --allow-dangerously-skip-permissions "$@"; return
        fi
      done
      echo "✓ proxy ready" >&2
    fi
    export ANTHROPIC_BASE_URL="$base"
  else
    unset ANTHROPIC_BASE_URL
    echo "⚠ headroom not installed — using direct API (run ~/.claude/doctor.sh)" >&2
  fi
  command claude --allow-dangerously-skip-permissions "$@"
}

