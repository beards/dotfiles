{
  "permissions": {
    "allow": [
      "mcp__plugin_discord_discord__reply",
      "mcp__plugin_discord_discord__react",
      "mcp__plugin_discord_discord__edit_message",
      "mcp__plugin_discord_discord__fetch_messages",
      "mcp__plugin_discord_discord__download_attachment"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git filter-branch *)"
    ],
    "defaultMode": "auto",
    "__deny": [
      "Bash(git reset --hard *)",
      "Bash(git rebase *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/account-info.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "codex@openai-codex": true,
    "superpowers@claude-plugins-official": true,
    "discord@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "serena@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": true,
    "claude-obsidian@claude-obsidian-marketplace": true
  },
  "extraKnownMarketplaces": {
    "claude-obsidian-marketplace": {
      "source": {
        "source": "github",
        "repo": "AgriciDaniel/claude-obsidian"
      }
    }
  },
  "language": "traditional chinese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "skipAutoPermissionPrompt": true,
  "autoMode": {
    "allow": [
      "Making change under source control is allowed: everything is revertable"
    ],
    "soft_deny": [
      "Do not run commands like `git rebase` or `git reset --hard` to break the source control history unless user explicitly ask to do that",
      "Never do `git push --force`"
    ]
  },
  "skipWorkflowUsageWarning": true
}
