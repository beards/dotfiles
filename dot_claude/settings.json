{
  "permissions": {
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git rebase *)",
      "Bash(git filter-branch *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/check-permission.sh"
          }
        ]
      }
    ]
  },
  "language": "traditional chinese",
  "skipDangerousModePermissionPrompt": true
}
